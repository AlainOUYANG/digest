---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const issues = (await getCollection('issues')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const base = import.meta.env.BASE_URL;
---

<Base title="归档 · Kzyo 每日简报" description="Kzyo 每日简报的全部往期列表。">
  <h1>归档</h1>
  <p class="issue-meta">共 {issues.length} 期</p>
  {
    issues.map((entry) => (
      <div class="archive-row">
        <a href={`${base}issues/${entry.id}/`}>{entry.data.title}</a>
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>
          {entry.data.date.toISOString().slice(0, 10)}
        </time>
      </div>
    ))
  }
</Base>
